# Copie estas variáveis no Railway → Variables (ambiente production)

DATABASE_URL=file:/data/prod.db

NEXTAUTH_URL=https://equiterceiros-production.up.railway.app

# Gere uma string aleatória longa (openssl rand -base64 32)
NEXTAUTH_SECRET=SUBSTITUA_POR_UMA_CHAVE_SECRETA_LONGA
AUTH_SECRET=SUBSTITUA_PELA_MESMA_CHAVE_ACIMA

# Opcional — S3
# S3_ENDPOINT=
# S3_BUCKET=equipamentos-docs
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=auto
