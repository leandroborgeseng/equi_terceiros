# Database (SQLite MVP / PostgreSQL production)
DATABASE_URL="file:./dev.db"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-secret-in-production"
# NextAuth v5 também aceita AUTH_SECRET (use o mesmo valor no Railway)
AUTH_SECRET="change-me-to-a-long-random-secret-in-production"
AUTH_TRUST_HOST="true"

# S3-compatible storage (Cloudflare R2 / Backblaze B2 / AWS S3)
S3_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
S3_BUCKET="equipamentos-docs"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="auto"
S3_PUBLIC_URL=""

# Armazenamento local (quando S3 não está configurado). Em produção no Railway use /data/uploads com volume.
UPLOAD_DIR="./uploads"

# App
APP_NAME="Homologação de Equipamentos"
APP_URL="http://localhost:3000"

# Branding — coloque o arquivo em public/ (ex.: public/logo.png)
NEXT_PUBLIC_LOGO_SRC="/logo.png"
NEXT_PUBLIC_LOGO_ALT="AION Engenharia"
NEXT_PUBLIC_APP_NAME="AION Engenharia — Gestão de Equipamentos de Terceiros"
# NEXT_PUBLIC_LOGO_SUBTITLE="Eng. Clínica"
